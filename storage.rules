// Firebase Storage Security Rules for Gym Pro App
// These rules allow authenticated users to:
// - Upload and update their own profile pictures
// - Read any profile pictures
// - Delete their own profile pictures
// - Upload news images (for admin)

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Rules for profile images
    match /profile_images/{imageId} {
      // Allow read access to all authenticated users
      allow read: if request.auth != null;
      
      // Allow write/delete access if user is authenticated and the image belongs to them
      allow write, delete: if request.auth != null 
        && request.auth.uid != null
        && imageId.matches('profile_' + request.auth.uid + '_.*');
    }
    
    // Rules for news images
    match /news_images/{imageId} {
      // Allow read access to all authenticated users
      allow read: if request.auth != null;
      
      // Allow write access to authenticated users (for admin panel)
      allow write: if request.auth != null;
      
      // Allow delete access to authenticated users (for admin panel)
      allow delete: if request.auth != null;
    }
    
    // Rules for product images
    match /products/{imageId} {
      // Allow read access to all authenticated users
      allow read: if request.auth != null;
      
      // Allow write access to authenticated users (for admin panel)
      allow write: if request.auth != null;
      
      // Allow delete access to authenticated users (for admin panel)
      allow delete: if request.auth != null;
    }
    
    // Default rule - deny access to all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
